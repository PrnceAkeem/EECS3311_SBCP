# ─────────────────────────────────────────────────────────────────────────────
# Synergy — Environment Variables Template
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# .env is gitignored and must never be committed.
# ─────────────────────────────────────────────────────────────────────────────

# Required: OpenRouter API key for the AI Customer Assistant chatbot (Qwen3-Plus model).
# Obtain one at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: Backend server port (default: 3000).
# When running with Docker this is set automatically by docker-compose.yml.
# PORT=3000

# Optional: PostgreSQL connection string (default shown below).
# When running with Docker this is set automatically by docker-compose.yml.
# DATABASE_URL=postgres://synergy_user:synergy_pass@localhost:5432/synergy
